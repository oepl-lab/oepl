{
  "$schema": "https://tr.designtokens.org/format/",
  "$metadata": {
    "name": "OEPL Design System",
    "version": "2.0.0",
    "description": "Design tokens for OEPL (Organic Electronics & Photovoltaics Lab)"
  },

  "color": {
    "$type": "color",

    "amber": {
      "$description": "Brand accent — warm amber scale",
      "50":  { "$value": "#FFF7EB", "$description": "Amber tint / background highlight" },
      "300": { "$value": "#FFD633", "$description": "Amber light / decorative" },
      "500": { "$value": "#E88800", "$description": "Amber base — primary brand accent" },
      "hover": { "$value": "#CC7700", "$description": "Amber hover state" },
      "dark":  { "$value": "#A86000", "$description": "Amber pressed / dark state" }
    },

    "neutral": {
      "$description": "Neutral grayscale — light to dark",
      "0":   { "$value": "#FFFFFF", "$description": "White" },
      "50":  { "$value": "#F7F7F7" },
      "100": { "$value": "#EDEDED" },
      "200": { "$value": "#E0E0E0" },
      "300": { "$value": "#C7C7C7" },
      "500": { "$value": "#8A8A8A" },
      "700": { "$value": "#4A4A4A" },
      "900": { "$value": "#1A1A1A" },
      "950": { "$value": "#0A0A0A", "$description": "Near-black" }
    },

    "dark": {
      "$description": "OEPL dark theme — neutral-900 (#1A1A1A) base",
      "bg":      { "$value": "#1A1A1A", "$description": "Page background — neutral-900" },
      "surface": { "$value": "#242424", "$description": "Surface / panel background" },
      "card":    { "$value": "#2e2e2e", "$description": "Card / elevated surface" },
      "border":  { "$value": "#3d3d3d", "$description": "Default border / divider" },
      "muted":   { "$value": "#F7F7F7", "$description": "Secondary text on dark bg — neutral-50" },
      "subtle":  { "$value": "#8A8A8A", "$description": "Tertiary text / placeholder — neutral-500" }
    }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "sans-en": {
        "$value": ["Pretendard", "system-ui", "sans-serif"],
        "$description": "Primary sans-serif for English/Latin text"
      },
      "sans-ko": {
        "$value": ["Noto Sans KR", "Pretendard", "sans-serif"],
        "$description": "Primary sans-serif for Korean text"
      },
      "mono": {
        "$value": ["IBM Plex Mono", "Menlo", "monospace"],
        "$description": "Monospace for code blocks"
      }
    },

    "size": {
      "$type": "dimension",
      "$description": "Type scale — pixel values",
      "xs":   { "$value": "12px", "$description": "Body Small (Body2)" },
      "sm":   { "$value": "13px", "$description": "Code" },
      "base": { "$value": "16px", "$description": "Body Base, Input, H7" },
      "lg":   { "$value": "18px", "$description": "H6" },
      "xl":   { "$value": "20px", "$description": "H5 / Subtitle" },
      "2xl":  { "$value": "24px", "$description": "H4 / Subheading" },
      "3xl":  { "$value": "36px", "$description": "H3 / Heading" },
      "4xl":  { "$value": "48px", "$description": "H2 / Title Page" },
      "5xl":  { "$value": "64px", "$description": "H1 / Title Hero" }
    },

    "weight": {
      "$type": "fontWeight",
      "regular":   { "$value": 400 },
      "medium":    { "$value": 500 },
      "semibold":  { "$value": 600 },
      "bold":      { "$value": 700 }
    },

    "lineHeight": {
      "$description": "Line-height scale (unitless ratio unless px specified)",
      "tight":    { "$value": 1.1,  "$description": "H1 / Hero" },
      "snug":     { "$value": 1.15, "$description": "H2" },
      "normal":   { "$value": 1.2,  "$description": "H3" },
      "relaxed":  { "$value": 1.3,  "$description": "H4" },
      "loose":    { "$value": 1.4,  "$description": "H5, H6" },
      "body":     { "$value": 1.5,  "$description": "H7, Body2, Code" },
      "body-px":  { "$value": "20px", "$description": "Body Base (fixed 20px)" }
    }
  },

  "typography": {
    "$description": "Composite typography tokens — mirrors OEPL/* text styles in Figma",
    "H1": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.5xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}" },
      "$description": "Title Hero · 64px / 1.1 / Bold"
    },
    "H2": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.4xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.snug}" },
      "$description": "Title Page · 48px / 1.15 / Bold"
    },
    "H3": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.3xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.normal}" },
      "$description": "Heading · 36px / 1.2 / Bold"
    },
    "H4": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.2xl}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.relaxed}" },
      "$description": "Subheading · 24px / 1.3 / Regular"
    },
    "H5": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.xl}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.loose}" },
      "$description": "Subtitle · 20px / 1.4 / Regular"
    },
    "H6": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.lg}", "fontWeight": "{font.weight.medium}", "lineHeight": "{font.lineHeight.loose}" },
      "$description": "H6 · 18px / 1.4 / Medium"
    },
    "H7": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.base}", "fontWeight": "{font.weight.medium}", "lineHeight": "{font.lineHeight.body}" },
      "$description": "H7 / Input · 16px / 1.5 / Medium"
    },
    "body": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.base}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.body-px}" },
      "$description": "Body Base · 16px / 20px / Regular"
    },
    "bodyStrong": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.base}", "fontWeight": "{font.weight.semibold}", "lineHeight": "{font.lineHeight.body-px}" },
      "$description": "Body Strong · 16px / 20px / Semi Bold"
    },
    "bodySmall": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.xs}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.body}" },
      "$description": "Body Small · 12px / 1.5 / Regular"
    },
    "bodySmallStrong": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.xs}", "fontWeight": "{font.weight.semibold}", "lineHeight": "{font.lineHeight.body}" },
      "$description": "Body Small Strong · 12px / 1.5 / Semi Bold"
    },
    "input": {
      "$value": { "fontFamily": "{font.family.sans-en}", "fontSize": "{font.size.base}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.loose}" },
      "$description": "Input · 16px / 1.4 / Regular"
    },
    "code": {
      "$value": { "fontFamily": "{font.family.mono}", "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.body}" },
      "$description": "Code · 13px / 1.5 / IBM Plex Mono"
    }
  },

  "space": {
    "$type": "dimension",
    "$description": "Spacing scale — used for gap and padding",
    "100": { "$value": "4px",   "$description": "gap.100 / padding.100" },
    "200": { "$value": "8px",   "$description": "gap.200 / padding.200" },
    "300": { "$value": "12px",  "$description": "gap.300 / padding.300" },
    "400": { "$value": "16px",  "$description": "gap.400 / padding.400" },
    "600": { "$value": "24px",  "$description": "gap.600 / padding.600" },
    "800": { "$value": "32px",  "$description": "gap.800 / padding.800" },
    "1200": { "$value": "48px", "$description": "gap.1200 / padding.1200" },
    "1600": { "$value": "64px", "$description": "gap.1600 / padding.1600" },
    "2400": { "$value": "96px", "$description": "padding.2400" },
    "3200": { "$value": "128px","$description": "padding.3200" },
    "4000": { "$value": "160px","$description": "padding.4000" }
  },

  "radius": {
    "$type": "dimension",
    "$description": "Border radius tokens",
    "sm":   { "$value": "4px",     "$description": "radius/4 — small" },
    "md":   { "$value": "8px",     "$description": "radius/8 — medium" },
    "lg":   { "$value": "16px",    "$description": "radius/16 — large" },
    "pill": { "$value": "9999px",  "$description": "radius/pill — fully rounded" }
  }
}
